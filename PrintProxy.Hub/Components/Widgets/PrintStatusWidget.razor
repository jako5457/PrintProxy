@using PrintProxy.Hub.Components.Account.Pages
@inject IDistributedCache _cache;
@inject IPrinterThumbnailService thumbnailService;
@inject NavigationManager nav;
@inject IDialogService Diag;
@inject AuthenticationStateProvider auth;

<MudItem sm="12" md="3">
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                @if (authorized)
                {
                    <MudText @onclick='() => nav.NavigateTo($"/details/{Uri.EscapeDataString(Printer.GetIdentifier())}")' Typo="Typo.h6" Style="cursor:pointer">@status.PrinterName <MudChip T="string" Size="Size.Small" Color="@status.Status.GetStatusColor()">@status.Status</MudChip></MudText>
                }
                else
                {
                    <MudText Typo="Typo.h6">@status.PrinterName <MudChip T="string" Size="Size.Small" Color="@status.Status.GetStatusColor()">@status.Status</MudChip></MudText>
                }

                @if (string.IsNullOrEmpty(status.FileName))
                {
                    <MudText Typo="Typo.caption">No file</MudText>
                }
                else
                {
                    <MudText Typo="Typo.caption">@status.FileName</MudText>
                }

            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            @if (!string.IsNullOrEmpty(image))
            {
                <MudImage Src="@image" Elevation="25" Class="rounded-lg" Width="150" Height="100" />
            }
            else
            {
                <MudPaper Class="pa-4 mud-dark rounded-lg shades-text text-white" Width="150px" Height="100px" Elevation="0">
                    <MudText Typo="Typo.h6">No image</MudText>
                </MudPaper>
            }

                <MudProgressLinear Color="Color.Info" Size="Size.Large" Value="status.Progress" Max="100" Class="my-7">
                    <MudText Typo="Typo.subtitle1" Color="Color.Dark">
                        <b>@(status.Progress)%</b>
                    </MudText>
                </MudProgressLinear>
                
                @if (!IsKiosk)
                {
                    <AuthorizeView>
                        <Authorized>
                            <MudButtonGroup OverrideStyles="false" >
                                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="() => Printer.ContinueAsync()">Continue</MudButton>
                                <MudButton Color="Color.Warning" Variant="Variant.Filled" OnClick="() => Printer.PauseAsync()">Pause</MudButton>
                            <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="OnPrinterStopAsync">Stop</MudButton>
                            </MudButtonGroup>
                        </Authorized>
                    </AuthorizeView>
                }
                
        </MudCardContent>
    </MudCard>
</MudItem>

@code {

    PrinterStatus status = new PrinterStatus();

    string image = string.Empty;

    bool IsBusy = false;

    bool updated = false;

    bool firstLoad = true;

    bool authorized = false;

    bool IsOffiline = false;

    [Parameter]
    public bool IsKiosk { get; set; } = false;

    [Parameter]
    public IPrinter Printer { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var authstate = await auth.GetAuthenticationStateAsync();
        authorized = authstate?.User?.Identity?.IsAuthenticated ?? false;
        await update();
        await base.OnInitializedAsync();
    }

    public async Task update()
    {
        if (IsBusy)
        {
            return;
        }

        if (updated)
        {
            return;
        }

        IsBusy = true;
        await InvokeAsync(StateHasChanged);

        DistributedCacheEntryOptions cacheoptions = new()
        {
            AbsoluteExpiration = DateTimeOffset.Now.AddSeconds(10)
        };

        string identifier = Printer.GetIdentifier();

        var cached = await _cache.GetStringAsync(identifier);

        if (cached != null)
        {
            if (firstLoad)
            {
                status = JsonConvert.DeserializeObject<PrinterStatus>(cached) ?? new PrinterStatus();
                IsBusy = false;
                await InvokeAsync(StateHasChanged);
            }
        }
        else
        {

            try
            {
                status = await Printer.GetStatusAsync();
            }
            catch (Exception e)
            {
                status = new PrinterStatus() { Status = "offline" };
                IsOffiline = true;
                throw;
            }

            if (!IsOffiline)
            {
                cached = JsonConvert.SerializeObject(status);

                await _cache.SetStringAsync(identifier, cached, cacheoptions);

                if (!string.IsNullOrEmpty(status.FileThumbnail))
                {
                    image = await thumbnailService.GetThumbnail(status.FileThumbnail.ToString());
                }
            }

            IsBusy = false;
            await InvokeAsync(StateHasChanged);
        }


    }

    protected override bool ShouldRender()
    {
        return true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!updated)
        {
            if (!IsBusy)
            {
                await update();
                updated = true;
            }
        }
        else
        {
            updated = false;
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    protected override Task OnParametersSetAsync()
    {


        return base.OnParametersSetAsync();
    }

    public async Task OnPrinterStopAsync()
    {
        var parameters = new DialogParameters<DefaultDialog>
        {
            { x => x.ContentText, "Do you really want to stop this printer? The printer cant continue the print." },
            { x => x.ButtonText, "Stop" },
            { x => x.Color, Color.Error }
        };

        var options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };

        var reference = await Diag.ShowAsync<DefaultDialog>("Stop print", parameters, options);

        var result = await reference.Result;

        if (!result?.Canceled ?? false)
        {
            await Printer.StopAsync();
        }
    }
}
