@page "/details/{id}"
@* @attribute [Authorize] *@
@inject IPrinterFactory printerFactory;

<PageTitle>Printer Details - @status.PrinterName</PageTitle>

@if (printer != null)
{
    <MudText HtmlTag="h1" >@status.PrinterName</MudText>
    <MudText HtmlTag="h5">@status.FileName</MudText>

    @if (!string.IsNullOrEmpty(image))
    {
        <MudImage Src="@image" Elevation="25" Class="rounded-lg" Width="150" Height="100" />
    }
    else
    {
        <MudPaper Class="pa-4 mud-dark rounded-lg shades-text text-white" Width="150px" Height="100px" Elevation="0">
            <MudText Typo="Typo.h6">No image</MudText>
        </MudPaper>
    }

    <MudProgressLinear Color="Color.Info" Size="Size.Large" Value="status.Progress" Max="100" Class="my-7">
        <MudText Typo="Typo.subtitle1" Color="Color.Dark">
            <b>@(status.Progress)%</b>
        </MudText>
    </MudProgressLinear>
}
else
{
    <MudText>No printer found</MudText>
}


@code {

    [Parameter]
    public string id { get; set; } = string.Empty;

    public IPrinter printer = null!;
    public PrinterStatus status = new PrinterStatus();
    public string image = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        printer = printerFactory.GetPrinterByIdentifier(id) ?? null!;

        status = await printer.GetStatusAsync();

        await base.OnInitializedAsync();
    }


}
