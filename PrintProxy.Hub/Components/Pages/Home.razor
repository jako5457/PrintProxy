@page "/"
@inject IPrinterFactory PrinterFactory
@inject IPrinterIndexService index
@inject ILogger<Home> _logger;
@inject NavigationManager nav;
<PageTitle>Printer overview</PageTitle>
<MudButton Variant="Variant.Filled" OnClick="ReloadAsync" Disabled="isbusy" Color="Color.Primary" Style="margin-top:2px;">Refresh</MudButton>

<MudGrid Style="margin-top:2px;">
    @foreach (var printer in Printers)
    {
        <PrintStatusWidget Printer="printer" IsKiosk="false" />
    }
</MudGrid>

@code {

    bool isbusy = true;

    public IEnumerable<IPrinter> Printers = new List<IPrinter>();

    protected override async Task OnInitializedAsync()
    {
        Printers = PrinterFactory.GetPrinters();

        await ReloadAsync();
        
        await base.OnInitializedAsync();
    }

    public async Task ReloadAsync()
    {
        isbusy = true;
        await InvokeAsync(StateHasChanged);
        isbusy = false;
        await InvokeAsync(StateHasChanged);
    }

}