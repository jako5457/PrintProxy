@page "/files"
@inject IPrinterfileService fileService
@attribute [Authorize]
@inject IDialogService Diag;
@inject IConfiguration config;

<MudTable T="PrinterFileInfo" Items="files" Loading="IsLoading" >
    <ToolBarContent>
        <MudText Typo="Typo.h6">Files</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Sync" title="Update"></MudIconButton>
        <MudIconButton Icon="@Icons.Material.Filled.Upload" OnClick="OnUploadAsync" title="Upload"></MudIconButton>
        <MudSpacer />
        <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Image</MudTh>
        <MudTh>FileName</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd><MudImage Width="75" Src="@LoadThumb(context)"/></MudTd>
        <MudTd>@context.FileInfo.Name</MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Delete" title="Delete" OnClick="() => DeleteFileAsync(context.FileInfo.Name)" Color="Color.Error"></MudIconButton>
            <MudIconButton Icon="@Icons.Material.Filled.Print" title="Print" OnClick="() => PrintAsync(context)" Color="Color.Info"></MudIconButton>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>No files found</MudText>
    </NoRecordsContent>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>



@code {
    List<PrinterFileInfo> files = new();

    string searchString = string.Empty;
    bool IsLoading = false;

    protected override async Task OnInitializedAsync()
    {
        await Update();
        await base.OnInitializedAsync();
    }

    public async Task Update()
    {
        IsLoading = true;
        files = fileService.GetFiles();
        IsLoading = false;
    }

    public string LoadThumb(PrinterFileInfo info)
    {
        string printerFilePath = config.GetValue<string>("GCODE_FILE_DIR", "GcodeFiles");

        var task = info.GetThumbnailAsync(printerFilePath);

        return task.GetAwaiter().GetResult();
    }

    public async Task OnUploadAsync()
    {
        var options = new DialogOptions() { CloseButton = false, MaxWidth = MaxWidth.ExtraSmall, BackdropClick = false };

        var reference = await Diag.ShowAsync<UploadDialog>("Upload",options);

        var result = await reference.Result;

        if (!result.Canceled)
        {
            await Update();
        }
    }

    public async Task DeleteFileAsync(string file)
    {
        await fileService.DeleteFileAsync(file);
        await Update();
    }

    public async Task PrintAsync(PrinterFileInfo file)
    {
        var parameters = new DialogParameters<PrintDialog>
        {
            { x => x.file, file }
        };

        var options = new DialogOptions() { CloseButton = false,BackdropClick = false, MaxWidth = MaxWidth.Medium };

        var reference = await Diag.ShowAsync<PrintDialog>($"Print {file.FileInfo.Name}", parameters, options);

        await reference.Result;
    }
}
